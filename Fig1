  # Skip if fitting fails
  if (inherits(glm_fit, "try-error")) {
    message("Skipping feature ", feature, ": GLM failed")
    next
  }
  
  # Save tidy results
  glm_summary <- broom::tidy(glm_fit)
  
  # Keep only Family term
  family_term <- glm_summary %>% filter(grepl("Family", term))
  
  results_list[[feature]] <- family_term
}

