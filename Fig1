get_cluster_PC1 <- function(count_mat_adj, celltype_clusters) {
  cluster_ids <- unique(celltype_clusters)
  
  pc1_mat <- matrix(nrow = nrow(count_mat_adj), ncol = length(cluster_ids))
  rownames(pc1_mat) <- rownames(count_mat_adj)
  colnames(pc1_mat) <- paste0("Cluster_", cluster_ids)
  
  for (cl in cluster_ids) {
    features <- names(celltype_clusters)[celltype_clusters == cl]
    features <- features[features %in% colnames(count_mat_adj)]
    if(length(features) == 0) {
      pc1_mat[, paste0("Cluster_", cl)] <- NA
      next
    }
    pca_res <- prcomp(count_mat_adj[, features, drop=FALSE], scale.=TRUE)
    pc1_mat[, paste0("Cluster_", cl)] <- pca_res$x[,1]
  }
  
  return(pc1_mat)
}


get_cluster_PC1_loadings <- function(count_mat_adj, celltype_clusters) {
  cluster_ids <- unique(celltype_clusters)
  pc1_loadings_list <- list()
  
  for (cl in cluster_ids) {
    features <- names(celltype_clusters)[celltype_clusters == cl]
    features <- features[features %in% colnames(count_mat_adj)]
    
    if (length(features) <= 1) {
      # Not enough features to run PCA
      pc1_loadings_list[[as.character(cl)]] <- NA
      next
    }
    
    pca_res <- prcomp(count_mat_adj[, features, drop = FALSE], scale. = TRUE)
    
    # Extract PC1 loadings (gene contributions)
    loadings <- pca_res$rotation[, 1]
    
    # Store as named vector
    pc1_loadings_list[[as.character(cl)]] <- loadings
  }
  
  names(pc1_loadings_list) <- paste0("Cluster_", cluster_ids)
  return(pc1_loadings_list)
}


cluster_PC1_loadings <- get_cluster_PC1_loadings(count_mat_adj, celltype_clusters)

plot_cluster_PC1_loadings <- function(cluster_PC1_loadings, top_n = NULL) {
  # Convert list to tidy data frame
  loadings_df <- bind_rows(
    lapply(names(cluster_PC1_loadings), function(cl) {
      vals <- cluster_PC1_loadings[[cl]]
      if (is.numeric(vals)) {
        data.frame(
          Gene = names(vals),
          Loading = vals,
          Cluster = cl,
          stringsAsFactors = FALSE
        )
      } else {
        NULL
      }
    }),
    .id = "id"
  )
  
  # Optionally keep top absolute loadings per cluster
  if (!is.null(top_n)) {
    loadings_df <- loadings_df %>%
      group_by(Cluster) %>%
      slice_max(order_by = abs(Loading), n = top_n)
  }
  
  # Order genes by descending loading within each cluster
  loadings_df <- loadings_df %>%
    group_by(Cluster) %>%
    arrange(desc(Loading), .by_group = TRUE) %>%
    mutate(Gene = factor(Gene, levels = unique(Gene)))
  
  # Plot
  p <- ggplot(loadings_df, aes(x = Loading, y = Gene, fill = Loading)) +
  geom_bar(stat = "identity") +
  facet_wrap(~ Cluster, scales = "free_y") +
  scale_fill_gradientn(
    colours = rev(brewer.pal(11, "RdYlBu")),
    limits = c(min(loadings_df$Loading, na.rm = TRUE),
               max(loadings_df$Loading, na.rm = TRUE)),
    oob = scales::squish,
    name = "PC1 Loading"
  ) +
  geom_vline(xintercept = 0, linetype = "dashed", color = "gray40") +
  theme_minimal(base_size = 40) +
  labs(
    x = "PC1 Loading",
    y = "Cell Type",
    title = "PC1 Loadings per Cell Type Cluster"
  ) +
  theme(
    strip.text = element_text(face = "bold", size = 50),
    axis.text.y = element_text(size = 50),
    axis.text.x = element_text(size = 50, angle = 45, hjust = 1),
    axis.title.x = element_text(size = 50),
    axis.title.y = element_text(size = 50),
    plot.title = element_text(size = 50))
  
  return(p)
}


